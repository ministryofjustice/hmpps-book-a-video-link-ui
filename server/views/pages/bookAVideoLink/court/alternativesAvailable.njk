{% extends "partials/layout.njk" %}

{% from "components/hmppsTimePicker.njk" import hmppsTimePicker %}
{% from "moj/components/date-picker/macro.njk" import mojDatePicker %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% set mode = session.req.routeContext.mode %}
{% set pageTitle = 'No bookings available for your selected time' %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-three-quarters">
            <h1 class="govuk-heading-l">{{ pageTitle }}</h1>
            <p>
                There are available bookings at other times on your selected date. Check for other availability or change the date.
            </p>
        </div>

    </div>

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-three-quarters">
            {{ govukSummaryList({
                classes: "govuk-summary-list--no-border",
                rows: [
                    {
                        key: {
                            text: "Date"
                        },
                        value: {
                            text: session.journey.bookACourtHearing.date | formatDate('dd MMMM yyyy')
                        }
                    },
                    {
                        key: {
                            text: "Pre-court hearing briefing time"
                        },
                        value: {
                            text: session.journey.bookACourtHearing.initialPreHearingStartTime | formatDate('HH:mm') + ' to ' + session.journey.bookACourtHearing.initialPreHearingEndTime | formatDate('HH:mm')
                        }
                    } if session.journey.bookACourtHearing.preHearingStartTime,
                    {
                        key: {
                            text: "Hearing time"
                        },
                        value: {
                            text: session.journey.bookACourtHearing.initialStartTime | formatDate('HH:mm') + ' to ' + session.journey.bookACourtHearing.initialEndTime | formatDate('HH:mm')
                        }
                    },
                    {
                        key: {
                            text: "Post-court hearing briefing time"
                        },
                        value: {
                            text: session.journey.bookACourtHearing.initialPostHearingStartTime | formatDate('HH:mm') + ' to ' + session.journey.bookACourtHearing.initialPostHearingEndTime | formatDate('HH:mm')
                        }
                    } if session.journey.bookACourtHearing.postHearingStartTime
                ],
                attributes: { 'data-qa': 'booking-details' }
            }) }}

            <div class="govuk-button-group">
                <a href="../video-link-booking" class="govuk-link govuk-link--no-visited-state govuk-!-font-size-19">Change</a>
            </div>
            <div class="govuk-button-group">
                {{ govukButton({
                    classes: 'govuk-button--blue',
                    text: "Check for other availability >",
                    href: "../video-link-booking/select-alternative-rooms"
                }) }}
            </div>
        </div>
    </div>
{% endblock %}
